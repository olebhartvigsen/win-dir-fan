<Project Sdk="WixToolset.Sdk/4.0.5">
  <PropertyGroup>
    <OutputName>FanFolderSetup</OutputName>
    <Platform>x64</Platform>
    <IntermediateOutputPath>obj\</IntermediateOutputPath>
    <OutputPath>output\</OutputPath>
    <!-- Override with: dotnet build -p:ProductVersion=1.2.3 -->
    <ProductVersion Condition="'$(ProductVersion)' == ''">1.0.0</ProductVersion>
    <DefineConstants>ProductVersion=$(ProductVersion)</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="WixToolset.UI.wixext" Version="4.0.5" />
  </ItemGroup>
</Project>
