<Project Sdk="WixToolset.Sdk/4.0.5">
  <PropertyGroup>
    <OutputName Condition="'$(OutputName)' == ''">FanFolderSetup</OutputName>
    <Platform Condition="'$(Platform)' == ''">x64</Platform>
    <IntermediateOutputPath>obj\$(Platform)\</IntermediateOutputPath>
    <OutputPath>output\</OutputPath>
    <!-- Override with: dotnet build -p:ProductVersion=1.2.3 -->
    <ProductVersion Condition="'$(ProductVersion)' == ''">1.0.0</ProductVersion>
    <DefineConstants>ProductVersion=$(ProductVersion)</DefineConstants>
    <!-- ICE91 warns about per-user dirs not varying on ALLUSERS — expected for perUser packages -->
    <SuppressIces>ICE91</SuppressIces>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="WixToolset.UI.wixext" Version="4.0.5" />
  </ItemGroup>
</Project>
