<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Bundle Name="FanFolder"
          Version="$(var.ProductVersion)"
          Manufacturer="Ole Bhartvigsen"
          UpgradeCode="F1A2B3C4-D5E6-7890-ABCD-EF1234567890">

    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
          LicenseUrl="https://github.com/olebhartvigsen/FanFolder/blob/main/LICENSE"
          Theme="hyperlinkLicense" />
    </BootstrapperApplication>

    <Chain>
      <!-- x64 MSI — installs on x64 Windows -->
      <MsiPackage Id="FanFolder_x64"
                  SourceFile="..\..\artifacts\x64\installer\output\FanFolderSetup-x64.msi"
                  InstallCondition="NOT NativeMachine = 43868">
        <MsiProperty Name="INSTALLFOLDER" Value="[LocalAppDataFolder]FanFolder\" />
      </MsiPackage>

      <!-- ARM64 MSI — installs on ARM64 Windows -->
      <MsiPackage Id="FanFolder_arm64"
                  SourceFile="..\..\artifacts\arm64\installer\output\FanFolderSetup-arm64.msi"
                  InstallCondition="NativeMachine = 43868">
        <MsiProperty Name="INSTALLFOLDER" Value="[LocalAppDataFolder]FanFolder\" />
      </MsiPackage>
    </Chain>

  </Bundle>
</Wix>
