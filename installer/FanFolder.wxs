<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="FanFolder"
           Version="$(var.ProductVersion)"
           Manufacturer="FanFolder"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           Language="1033"
           Scope="perUser">

    <SummaryInformation Description="FanFolder — macOS-style fan menu for the Windows taskbar" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of FanFolder is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- ── Directories ───────────────────────────────────────── -->

    <!-- %LOCALAPPDATA%\FanFolder -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="FanFolder" />
    </StandardDirectory>

    <!-- %APPDATA%\Microsoft\Windows\Start Menu\Programs\FanFolder -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="StartMenuFanFolder" Name="FanFolder" />
    </StandardDirectory>

    <!-- Desktop -->
    <StandardDirectory Id="DesktopFolder" />

    <!-- ── Main executable ───────────────────────────────────── -->
    <ComponentGroup Id="AppComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExe" Guid="B1C2D3E4-F5A6-7890-BCDE-F12345678901">
        <File Id="FanFolderExe"
              Source="..\FanFolder\build\Release\FanFolder.exe"
              Name="FanFolder.exe" />
        <!-- Per-user install requires HKCU registry KeyPath, not a file (ICE38) -->
        <RegistryValue Root="HKCU"
                       Key="Software\FanFolder"
                       Name="InstallDir"
                       Value="[INSTALLFOLDER]"
                       Type="string"
                       KeyPath="yes" />
        <RemoveFolder Id="RemoveInstallFolder" Directory="INSTALLFOLDER" On="uninstall" />
      </Component>
    </ComponentGroup>

    <!-- ── Shortcuts ─────────────────────────────────────────── -->
    <ComponentGroup Id="ShortcutComponents">

      <!-- Start Menu shortcut -->
      <Component Id="StartMenuShortcut" Directory="StartMenuFanFolder"
                 Guid="32923206-A517-4419-9100-57A6B94A6F26">
        <Shortcut Id="StartMenuShortcutLink"
                  Name="FanFolder"
                  Description="macOS-style fan folder for the Windows taskbar"
                  Target="[INSTALLFOLDER]FanFolder.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveStartMenuFolder" Directory="StartMenuFanFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\FanFolder\Shortcuts"
                       Name="StartMenu"
                       Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>

      <!-- Desktop shortcut -->
      <Component Id="DesktopShortcut" Directory="DesktopFolder"
                 Guid="4779D22A-85B8-4033-B2F2-F884E464D4C3">
        <Shortcut Id="DesktopShortcutLink"
                  Name="FanFolder"
                  Description="macOS-style fan folder for the Windows taskbar"
                  Target="[INSTALLFOLDER]FanFolder.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\FanFolder\Shortcuts"
                       Name="Desktop"
                       Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>

    </ComponentGroup>

    <!-- ── Auto-start on login (HKCU Run key) ────────────────── -->
    <ComponentGroup Id="StartupComponents" Directory="INSTALLFOLDER">
      <Component Id="StartupRegistry" Guid="C2D3E4F5-A6B7-8901-CDEF-123456789012">
        <RegistryValue Root="HKCU"
                       Key="Software\Microsoft\Windows\CurrentVersion\Run"
                       Name="FanFolder"
                       Value="&quot;[INSTALLFOLDER]FanFolder.exe&quot;"
                       Type="string"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── Features ──────────────────────────────────────────── -->
    <Feature Id="ProductFeature" Title="FanFolder" Level="1">
      <ComponentGroupRef Id="AppComponents" />
      <ComponentGroupRef Id="ShortcutComponents" />
      <ComponentGroupRef Id="StartupComponents" />
    </Feature>

    <!-- ── Minimal UI (license screen + install) ─────────────── -->
    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

  </Package>
</Wix>
